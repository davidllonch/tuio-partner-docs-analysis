# DATABASE_URL is injected automatically by docker-compose using the DB_PASSWORD
# from the root .env file. You do NOT need to set it here.
# DATABASE_URL=postgresql+asyncpg://kyc_user:YOUR_PASSWORD@db:5432/kyc_db

# Auth
JWT_SECRET_KEY=change-this-to-a-random-32-char-string-minimum

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Email (Resend)
RESEND_API_KEY=re_...
REPORT_EMAIL_RECIPIENT=legal@tuio.com
EMAIL_FROM_ADDRESS=kyc@tuio.com

# Storage (inside Docker — matches the volume mount in docker-compose.yml)
DOCUMENTS_BASE_PATH=/data/documents

# CORS — your production frontend domain (must match FRONTEND_BASE_URL and the Traefik domain)
CORS_ORIGINS=https://tuiopartnersdocs.42labs.es

# Frontend base URL — used to build invitation links sent to partners
FRONTEND_BASE_URL=https://tuiopartnersdocs.42labs.es
